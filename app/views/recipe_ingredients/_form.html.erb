<%= form_with(model: recipe_ingredient, class: "contents") do |form| %>
  <% if recipe_ingredient.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(recipe_ingredient.errors.count, "error") %> prohibited this recipe_ingredient from being saved:</h2>

      <ul class="list-disc ml-6">
        <% recipe_ingredient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5 font-bold text-2xl">
    <%= @recipe.name %>
    <%= form.hidden_field :recipe_id, value: @recipe.id %>
  </div>

  <div class="my-5">
    <%= form.label :amount %>
    <%= form.text_field :amount, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": recipe_ingredient.errors[:amount].none?, "border-red-400 focus:outline-red-600": recipe_ingredient.errors[:amount].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :unit_id %>
    <%= form.collection_select :unit_id, Unit.order(:name), :id, :name, { prompt: "Select a unit" }, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": recipe_ingredient.errors[:unit_id].none?, "border-red-400 focus:outline-red-600": recipe_ingredient.errors[:unit_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :ingredient_id %>
    <%= form.collection_select :ingredient_id, Ingredient.order(:name), :id, :name, { prompt: "Select an ingredient" }, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": recipe_ingredient.errors[:ingredient_id].none?, "border-red-400 focus:outline-red-600": recipe_ingredient.errors[:ingredient_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
