<div id="<%= dom_id recipe %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= recipe.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= recipe.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Directions:</strong>
    <div class="prose text-black marker:text-black">
      <%= markdown(recipe.directions) %>
    </div>
  </div>
</div>
