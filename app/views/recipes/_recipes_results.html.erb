<%= turbo_frame_tag "recipes_results" do %>
  <div id="recipes" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if recipes.any? %>
      <% recipes.each do |recipe| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <div id="<%= dom_id recipe %>" class="w-full sm:w-auto my-5 space-y-5">
            <div>
              <strong class="block font-medium text-2xl mb-1"><%= recipe.name %></strong>
            </div>
            <div>
              <strong class="block font-medium mb-1">Description:</strong>
              <%= recipe.description %>
            </div>
          </div>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", recipe, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium mb-2" %>
            <%= link_to "Edit", edit_recipe_path(recipe), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium mb-2" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No recipes found.</p>
    <% end %>
  </div>
<% end %>