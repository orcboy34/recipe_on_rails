<% content_for :title, "Tags" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-2">
    <h1 class="font-bold text-4xl">Tags</h1>
    <%= link_to "New tag", new_tag_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="tags" class="grid grid-cols-3 min-w-full gap-3">
    <% if @tags.any? %>
      <% @tags.each do |tag| %>
        <%= link_to edit_tag_path(tag), class: "flex justify-between items-top bg-blue-50 border-2 border-blue-200 rounded-md p-2" do %>
          <div class="flex flex-col sm:flex-row space-x-2 space-y-2">
              <%= render tag %>
          </div>
          <%= button_to fa_icon("trash"), tag, method: :delete, title: "Remove", class: "w-full sm:w-auto px-3.5 py-2.5 text-red-400 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" }%>
          <% end %>
      <% end %>
    <% else %>
      <p class="text-center my-10">No tags found.</p>
    <% end %>
  </div>
</div>
