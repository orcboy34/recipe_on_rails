<% content_for :title, "Units" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-2">
    <h1 class="font-bold text-4xl">Units</h1>
    <%= link_to fa_icon("plus"), new_unit_path, title: "New unit", class: "aspect-square rounded-full size-10 flex items-center justify-center bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>
  <%= render "shared/search_form", url: units_path, search_placeholder: "units" %>

  <div id="units" class="grid grid-cols-3 min-w-full gap-3 mt-4">
    <% if @units.any? %>
      <% @units.each do |unit| %>
        <%= link_to edit_unit_path(unit), class: "flex justify-between items-top bg-blue-50 border-2 border-blue-200 rounded-md p-2" do %>
          <div class="flex flex-col sm:flex-row space-x-2 space-y-2">
              <%= render unit %>
          </div>
          <% end %>
      <% end %>
    <% else %>
      <p class="text-center my-10">No units found.</p>
    <% end %>
  </div>
</div>
